		isNameInferred
		sourceColumn: [Periodo Mes Anterior]

		variation Variation
			isDefault
			relationship: ad8d240b-a9c7-41e7-9856-d9a3a282718c
			defaultHierarchy: LocalDateTable_c96b7b66-de9d-47a9-bd82-c723f9d505dd.'Hierarquia de datas'

		annotation SummarizationSetBy = Automatic

	partition d_calendario = calculated
		mode: import
		source =
				
				VAR DataMin = MINX(ALL('tb_respostas'), 'tb_respostas'[DataAvaliacao])
				VAR DataMax = MAXX(ALL('tb_respostas'), 'tb_respostas'[DataAvaliacao])
				RETURN
				ADDCOLUMNS(
				    CALENDAR(DataMin, DataMax),
				
				    "Ano", YEAR([Date]),
				    "Mes", MONTH([Date]),
				    "Nome Mes", FORMAT([Date], "MMMM"),
				    "Ano-Mes", FORMAT([Date], "YYYY-MM"),
				    "Trimestre", "T" & FORMAT([Date], "Q"),
				    "Semana Ano", WEEKNUM([Date], 2),
				    "Dia", DAY([Date]),
				    "Dia Semana", WEEKDAY([Date], 2),
				    "Nome Dia", FORMAT([Date], "DDDD"),
				    "Ano-Semana", FORMAT([Date], "YYYY") & "-" & FORMAT(WEEKNUM([Date],2), "00"),
				    "Periodo Mes Anterior", EDATE([Date], -1)
				)

	annotation PBI_Id = 84fdbd0a3533432db381467d1d12f3e1

